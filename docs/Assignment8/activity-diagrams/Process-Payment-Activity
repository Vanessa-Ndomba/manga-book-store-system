flowchart TD
    Start([Start])

    subgraph User
        U1[Select payment method]
        U2[Enter payment details]
        U3[Submit payment]
    end

    subgraph System
        S1[Send payment request]
        S2{Payment approved?}
        S3[Confirm order]
        S4[Display payment failure]
    end

    subgraph ParallelTasks
        P1[Send confirmation email]
        P2[Update inventory records]
    end

    End([End])

    Start --> U1 --> U2 --> U3 --> S1 --> S2
    S2 -- Yes --> S3
    S3 --> P1
    S3 --> P2
    P1 --> End
    P2 --> End
    S2 -- No --> S4 --> End
